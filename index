<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bacterial Classification Atlas — Medical Microbiology</title>
<style>
/* ============================================================
   DESIGN TOKENS
   ============================================================ */
:root {
  /* Paper / academic theme */
  --paper-bg: #F8F5EE;
  --paper-bg-deep: #F1ECE0;
  --card-bg: #FCFAF5;
  --card-bg-white: #FFFFFF;
  --ink: #2E2E2E;
  --ink-soft: #5A5650;
  --line-soft: #C9C2B4;
  --line-softer: #DDD7C8;
  --rule: #B8AF9C;

  /* Category accents (muted, desaturated) */
  --c-grampos: #3D4F66;       /* muted navy */
  --c-grampos-bg: #E8ECF1;
  --c-gramneg: #6B7456;       /* muted olive */
  --c-gramneg-bg: #EBEEE3;
  --c-acidfast: #9C6B3F;      /* muted brown/orange */
  --c-acidfast-bg: #F2E9DD;
  --c-intracellular: #6B5B7A; /* muted purple */
  --c-intracellular-bg: #ECE7F0;
  --c-other: #7A6F5C;         /* neutral for spirochetes/cell-wall-deficient */
  --c-other-bg: #EEEAE0;

  /* Functional */
  --accent: #8A4B3B;          /* terracotta-ish, used sparingly for active states */
  --accent-bg: #F3E6E1;
  --shadow-soft: 0 1px 3px rgba(46,46,46,0.08), 0 1px 2px rgba(46,46,46,0.06);
  --shadow-card: 0 2px 8px rgba(46,46,46,0.07), 0 1px 3px rgba(46,46,46,0.05);
  --shadow-panel: -2px 0 12px rgba(46,46,46,0.06);

  /* Type scale */
  --font-display: 'Source Serif Pro', 'Iowan Old Style', Georgia, 'Times New Roman', serif;
  --font-body: 'Inter', -apple-system, 'Segoe UI', sans-serif;
  --font-mono: 'IBM Plex Mono', 'SF Mono', Consolas, monospace;
}

* { box-sizing: border-box; }
html, body {
  margin: 0; padding: 0;
  background: var(--paper-bg);
  color: var(--ink);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.001ms !important;
    transition-duration: 0.001ms !important;
  }
}

::selection { background: #D9CBB8; }

a { color: var(--accent); }

/* Scrollbar styling for webkit */
::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--line-soft); border-radius: 6px; }
::-webkit-scrollbar-thumb:hover { background: var(--rule); }

/* ============================================================
   LAYOUT SHELL
   ============================================================ */
.app-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ---- Header ---- */
.app-header {
  flex: 0 0 auto;
  background: var(--card-bg-white);
  border-bottom: 1px solid var(--line-softer);
  padding: 14px 22px;
  display: flex;
  align-items: center;
  gap: 18px;
  flex-wrap: wrap;
  z-index: 50;
}
.app-title {
  font-family: var(--font-display);
  font-size: 1.35rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: var(--ink);
  margin: 0;
  white-space: nowrap;
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.app-title .eyebrow {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-soft);
  background: var(--paper-bg-deep);
  border: 1px solid var(--line-softer);
  padding: 3px 7px;
  border-radius: 3px;
}

.search-wrap {
  position: relative;
  flex: 1 1 280px;
  min-width: 200px;
  max-width: 440px;
}
.search-input {
  width: 100%;
  font-family: var(--font-body);
  font-size: 0.92rem;
  padding: 9px 14px 9px 36px;
  border: 1.5px solid var(--line-soft);
  border-radius: 8px;
  background: var(--paper-bg);
  color: var(--ink);
  outline: none;
  transition: border-color 0.15s ease, background 0.15s ease;
}
.search-input:focus {
  border-color: var(--accent);
  background: var(--card-bg-white);
}
.search-input::placeholder { color: var(--ink-soft); opacity: 0.7; }
.search-icon {
  position: absolute;
  left: 12px; top: 50%;
  transform: translateY(-50%);
  width: 16px; height: 16px;
  color: var(--ink-soft);
  pointer-events: none;
}
.search-clear {
  position: absolute;
  right: 8px; top: 50%;
  transform: translateY(-50%);
  background: none; border: none;
  color: var(--ink-soft);
  cursor: pointer;
  font-size: 1.1rem;
  line-height: 1;
  padding: 4px;
  display: none;
}
.search-clear.visible { display: block; }

.search-results-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  left: 0; right: 0;
  background: var(--card-bg-white);
  border: 1px solid var(--line-softer);
  border-radius: 8px;
  box-shadow: var(--shadow-card);
  max-height: 360px;
  overflow-y: auto;
  z-index: 100;
  display: none;
}
.search-results-dropdown.visible { display: block; }
.search-result-item {
  padding: 9px 14px;
  cursor: pointer;
  border-bottom: 1px solid var(--line-softer);
  font-size: 0.88rem;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.search-result-item:last-child { border-bottom: none; }
.search-result-item:hover, .search-result-item.active-hover { background: var(--paper-bg-deep); }
.search-result-name { font-weight: 600; color: var(--ink); font-style: italic; }
.search-result-path { font-size: 0.74rem; color: var(--ink-soft); font-family: var(--font-mono); }
.search-no-results { padding: 14px; color: var(--ink-soft); font-size: 0.85rem; text-align: center; }

.header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
}

.btn {
  font-family: var(--font-body);
  font-size: 0.84rem;
  font-weight: 600;
  padding: 8px 14px;
  border-radius: 7px;
  border: 1.5px solid var(--line-soft);
  background: var(--card-bg-white);
  color: var(--ink);
  cursor: pointer;
  transition: all 0.15s ease;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}
.btn:hover { background: var(--paper-bg-deep); border-color: var(--rule); }
.btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
.btn.btn-primary {
  background: var(--ink);
  color: var(--paper-bg);
  border-color: var(--ink);
}
.btn.btn-primary:hover { background: #1c1c1c; }
.btn.btn-active {
  background: var(--accent-bg);
  border-color: var(--accent);
  color: var(--accent);
}
.btn svg { width: 15px; height: 15px; flex: 0 0 auto; }
.btn.icon-only { padding: 8px; }

.filter-badge {
  background: var(--accent);
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  border-radius: 10px;
  padding: 1px 6px;
  margin-left: 2px;
}

/* ---- Filter Panel (expandable below header) ---- */
.filter-panel {
  flex: 0 0 auto;
  background: var(--paper-bg-deep);
  border-bottom: 1px solid var(--line-softer);
  padding: 0 22px;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.25s ease, padding 0.25s ease;
}
.filter-panel.open {
  max-height: 220px;
  padding: 14px 22px;
  overflow-y: auto;
}
.filter-groups {
  display: flex;
  flex-wrap: wrap;
  gap: 22px;
}
.filter-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.filter-group-label {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.filter-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  max-width: 480px;
}
.filter-chip {
  font-size: 0.78rem;
  padding: 5px 11px;
  border-radius: 14px;
  border: 1.3px solid var(--line-soft);
  background: var(--card-bg-white);
  color: var(--ink-soft);
  cursor: pointer;
  transition: all 0.12s ease;
  user-select: none;
}
.filter-chip:hover { border-color: var(--rule); }
.filter-chip.active {
  background: var(--ink);
  color: var(--paper-bg);
  border-color: var(--ink);
}
.filter-clear-link {
  font-size: 0.76rem;
  color: var(--accent);
  cursor: pointer;
  text-decoration: underline;
  align-self: flex-start;
  margin-top: 2px;
}

/* ---- Main content area ---- */
.main-area {
  flex: 1 1 auto;
  display: flex;
  overflow: hidden;
  position: relative;
}

.tree-pane {
  flex: 1 1 auto;
  overflow: auto;
  padding: 28px 24px 80px 24px;
  position: relative;
}
.tree-pane.dimmed-for-compare {
  opacity: 0.45;
  pointer-events: none;
}

/* ============================================================
   TREE / FLOWCHART RENDERING
   ============================================================ */
.tree-root-node {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
}

.tree-node-wrap {
  position: relative;
  padding-left: 30px;
  margin-left: 9px;
  border-left: 1.5px solid var(--line-soft);
}
.tree-node-wrap.no-line { border-left: none; padding-left: 0; margin-left: 0; }
.tree-node-wrap:last-child { }

.tree-node-row {
  position: relative;
  margin: 7px 0;
}
.tree-node-row::before {
  /* horizontal connector stub from vertical line to node */
  content: '';
  position: absolute;
  left: -30px;
  top: 16px;
  width: 30px;
  height: 1.5px;
  background: var(--line-soft);
}
.tree-node-wrap.no-line > .tree-node-row::before { display: none; }

.tree-node-box {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-radius: 9px;
  border: 1.5px solid var(--line-soft);
  background: var(--card-bg);
  cursor: pointer;
  font-size: 0.88rem;
  line-height: 1.3;
  user-select: none;
  transition: box-shadow 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
  max-width: 560px;
}
.tree-node-box:hover {
  box-shadow: var(--shadow-soft);
  border-color: var(--rule);
}
.tree-node-box:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 1px;
}
.tree-node-box.search-match {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px var(--accent-bg);
}
.tree-node-box.search-current {
  background: var(--accent-bg);
}

/* Node type variants */
.tree-node-box.type-root {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  padding: 14px 26px;
  border-width: 2px;
  border-color: var(--ink);
  background: var(--card-bg-white);
}
.tree-node-box.type-category {
  font-weight: 700;
  font-size: 0.92rem;
  letter-spacing: 0.01em;
}
.tree-node-box.type-genus {
  font-weight: 600;
  font-style: italic;
}
.tree-node-box.type-test {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  font-weight: 500;
  background: transparent;
  border-style: dashed;
  color: var(--ink-soft);
  padding: 6px 12px;
}
.tree-node-box.type-test:hover { color: var(--ink); }
.tree-node-box.type-supplemental_test {
  font-family: var(--font-mono);
  font-size: 0.74rem;
  background: #FBF6E8;
  border-style: dotted;
  border-color: #C9B888;
  color: #7A6328;
}
.tree-node-box.type-organism {
  font-style: italic;
  font-weight: 600;
  background: var(--card-bg-white);
  border-width: 1.5px;
}
.tree-node-box.type-organism .sci-name { font-style: italic; }
.tree-node-box.type-organism.in-comparison {
  border-color: var(--accent);
  background: var(--accent-bg);
}

/* Category color left-bars */
.tree-node-box.cat-grampos { border-left: 4px solid var(--c-grampos); }
.tree-node-box.cat-gramneg { border-left: 4px solid var(--c-gramneg); }
.tree-node-box.cat-acidfast { border-left: 4px solid var(--c-acidfast); }
.tree-node-box.cat-intracellular { border-left: 4px solid var(--c-intracellular); }
.tree-node-box.cat-other { border-left: 4px solid var(--c-other); }

.tree-node-note {
  font-family: var(--font-body);
  font-style: normal;
  font-size: 0.72rem;
  color: var(--ink-soft);
  font-weight: 400;
  margin-left: 4px;
}

.tree-toggle-icon {
  width: 14px; height: 14px;
  flex: 0 0 auto;
  transition: transform 0.18s ease;
  color: var(--ink-soft);
}
.tree-toggle-icon.expanded { transform: rotate(90deg); }
.tree-toggle-icon.leaf { visibility: hidden; }

.tree-children-container {
  overflow: hidden;
  transition: none;
}
.tree-children-container.collapsed { display: none; }

.tree-compare-checkbox {
  width: 15px; height: 15px;
  flex: 0 0 auto;
  cursor: pointer;
  accent-color: var(--accent);
}

.tree-organism-count-tag {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--ink-soft);
  background: var(--paper-bg-deep);
  border-radius: 8px;
  padding: 1px 7px;
  margin-left: 4px;
}

/* ============================================================
   SIDE PANEL — organism detail
   ============================================================ */
.side-panel {
  flex: 0 0 auto;
  width: 0;
  background: var(--card-bg-white);
  border-left: 1px solid var(--line-softer);
  box-shadow: var(--shadow-panel);
  overflow: hidden;
  transition: width 0.22s ease;
  display: flex;
  flex-direction: column;
}
.side-panel.open {
  width: min(480px, 42vw);
}
@media (max-width: 880px) {
  .side-panel.open { width: 100vw; position: absolute; right: 0; top: 0; bottom: 0; z-index: 80; }
}

.side-panel-inner {
  width: min(480px, 42vw);
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}
@media (max-width: 880px) {
  .side-panel-inner { width: 100vw; }
}

.panel-header {
  flex: 0 0 auto;
  padding: 18px 22px 14px 22px;
  border-bottom: 1px solid var(--line-softer);
  position: relative;
}
.panel-close-btn {
  position: absolute;
  top: 14px; right: 14px;
  background: none; border: none;
  cursor: pointer;
  color: var(--ink-soft);
  padding: 6px;
  border-radius: 6px;
  line-height: 0;
}
.panel-close-btn:hover { background: var(--paper-bg-deep); color: var(--ink); }
.panel-close-btn svg { width: 18px; height: 18px; }

.panel-classification-path {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--ink-soft);
  letter-spacing: 0.01em;
  margin-bottom: 8px;
  line-height: 1.5;
}
.panel-org-name {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0 0 6px 0;
  padding-right: 30px;
  line-height: 1.25;
}
.panel-gram-badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 12px;
  margin-top: 2px;
}
.panel-gram-badge.cat-grampos { background: var(--c-grampos-bg); color: var(--c-grampos); }
.panel-gram-badge.cat-gramneg { background: var(--c-gramneg-bg); color: var(--c-gramneg); }
.panel-gram-badge.cat-acidfast { background: var(--c-acidfast-bg); color: var(--c-acidfast); }
.panel-gram-badge.cat-intracellular { background: var(--c-intracellular-bg); color: var(--c-intracellular); }
.panel-gram-badge.cat-other { background: var(--c-other-bg); color: var(--c-other); }

.panel-body {
  flex: 1 1 auto;
  overflow-y: auto;
  padding: 6px 22px 28px 22px;
}

.panel-section {
  margin-top: 18px;
  padding-top: 14px;
  border-top: 1px solid var(--line-softer);
}
.panel-section:first-child { margin-top: 14px; padding-top: 0; border-top: none; }

.panel-section-title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--ink-soft);
  margin: 0 0 8px 0;
  display: flex;
  align-items: center;
  gap: 6px;
}
.panel-section-title svg { width: 13px; height: 13px; }

.panel-field-grid {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 6px 12px;
  font-size: 0.86rem;
}
.panel-field-label {
  font-weight: 600;
  color: var(--ink-soft);
  white-space: nowrap;
}
.panel-field-value { color: var(--ink); }

.panel-list {
  margin: 0;
  padding-left: 18px;
  font-size: 0.86rem;
  line-height: 1.55;
  color: var(--ink);
}
.panel-list li { margin-bottom: 5px; }
.panel-list li:last-child { margin-bottom: 0; }

.panel-prose {
  font-size: 0.86rem;
  line-height: 1.6;
  color: var(--ink);
  margin: 0;
}

.panel-pearls-box {
  background: var(--accent-bg);
  border-left: 3px solid var(--accent);
  border-radius: 6px;
  padding: 12px 14px;
}
.panel-pearls-box .panel-list { color: #5C3528; }

.supplemental-tag {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.66rem;
  background: #FBF6E8;
  border: 1px solid #C9B888;
  color: #7A6328;
  padding: 1px 8px;
  border-radius: 8px;
  margin-bottom: 6px;
}

/* Expandable sections (collapsed by default) */
.panel-expandable-toggle {
  width: 100%;
  text-align: left;
  background: var(--paper-bg-deep);
  border: 1px solid var(--line-softer);
  border-radius: 8px;
  padding: 11px 14px;
  font-family: var(--font-body);
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--ink);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10px;
  transition: background 0.15s ease;
}
.panel-expandable-toggle:hover { background: var(--line-softer); }
.panel-expandable-toggle svg {
  width: 15px; height: 15px;
  transition: transform 0.18s ease;
  flex: 0 0 auto;
}
.panel-expandable-toggle.expanded svg { transform: rotate(180deg); }
.panel-expandable-content {
  padding: 14px 4px 4px 4px;
  display: none;
}
.panel-expandable-content.expanded { display: block; }

.panel-footer-actions {
  flex: 0 0 auto;
  padding: 12px 22px;
  border-top: 1px solid var(--line-softer);
  display: flex;
  gap: 8px;
}

.panel-empty-state {
  padding: 60px 30px;
  text-align: center;
  color: var(--ink-soft);
}
.panel-empty-state svg { width: 40px; height: 40px; margin-bottom: 12px; opacity: 0.5; }
.panel-empty-state p { font-size: 0.88rem; line-height: 1.5; margin: 0; }

/* ============================================================
   COMPARISON TRAY + MODAL
   ============================================================ */
.compare-tray {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--card-bg-white);
  border-top: 1.5px solid var(--ink);
  box-shadow: 0 -4px 16px rgba(46,46,46,0.12);
  padding: 12px 22px;
  display: none;
  align-items: center;
  gap: 14px;
  z-index: 60;
  flex-wrap: wrap;
}
.compare-tray.visible { display: flex; }
.compare-tray-label {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--ink-soft);
  white-space: nowrap;
}
.compare-tray-chips {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  flex: 1 1 auto;
}
.compare-tray-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--accent-bg);
  color: var(--accent);
  border-radius: 14px;
  padding: 5px 6px 5px 12px;
  font-size: 0.82rem;
  font-style: italic;
  font-weight: 600;
}
.compare-tray-chip button {
  background: none; border: none; cursor: pointer;
  color: var(--accent);
  font-size: 0.95rem;
  line-height: 1;
  padding: 2px 4px;
}

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(46,46,46,0.45);
  z-index: 200;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 30px;
}
.modal-overlay.visible { display: flex; }
.compare-modal {
  background: var(--paper-bg);
  border-radius: 14px;
  max-width: min(1100px, 94vw);
  max-height: 88vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 12px 40px rgba(0,0,0,0.25);
}
.compare-modal-header {
  flex: 0 0 auto;
  padding: 18px 24px;
  border-bottom: 1px solid var(--line-softer);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card-bg-white);
}
.compare-modal-title {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
