<script>
/* ============================================================
   APPLICATION STATE
   ============================================================ */
const state = {
  expandedNodes: new Set(['root']),   // node ids currently expanded
  selectedOrganismId: null,
  compareList: [],                     // array of organismIds
  activeFilters: { gram: new Set(), oxygen: new Set(), category: new Set() },
  searchQuery: '',
  searchMatchIds: new Set(),           // node ids that match current search (tree node ids, not organism ids)
  expandablePanelOpen: false
};

const CATEGORY_LABELS = {
  grampos: 'Gram-Positive',
  gramneg: 'Gram-Negative',
  acidfast: 'Acid-Fast',
  intracellular: 'Intracellular',
  other: 'Other'
};

// Map each organism to a category color class based on its DB entry's classificationPath / gramReaction
function getOrganismCategory(org) {
  const path = org.classificationPath.toLowerCase();
  const gram = org.gramReaction.toLowerCase();
  if (path.includes('obligate intracellular') || path.includes('cell wall-deficient')) return 'intracellular';
  if (path.includes('acid-fast')) return 'acidfast';
  if (path.includes('spirochete')) return 'other';
  if (gram.includes('gram-positive')) return 'grampos';
  if (gram.includes('gram-negative')) return 'gramneg';
  return 'other';
}

// Precompute category for every organism
ORGANISM_DB.forEach(o => { o._category = getOrganismCategory(o); });

// Map tree category node ids to color classes directly (set in tree data's "category" field)
function getCategoryClass(catKey) {
  return 'cat-' + (catKey || 'other');
}

/* ============================================================
   HELPERS
   ============================================================ */
function escapeHtml(str) {
  if (str === undefined || str === null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function highlightMatch(text, query) {
  if (!query) return escapeHtml(text);
  const escaped = escapeHtml(text);
  const idx = escaped.toLowerCase().indexOf(query.toLowerCase());
  if (idx === -1) return escaped;
  return escaped.slice(0, idx) + '<mark style="background:#F3E6E1;color:#8A4B3B;border-radius:2px;">' +
         escaped.slice(idx, idx + query.length) + '</mark>' + escaped.slice(idx + query.length);
}

function debounce(fn, delay) {
  let timer = null;
  return function(...args) {
    clearTimeout(timer);
    timer = setTimeout(() => fn.apply(this, args), delay);
  };
}

// Recursively walk the tree, calling cb(node, parentChain) for every node
function walkTree(node, cb, parents = []) {
  cb(node, parents);
  if (node.children) {
    node.children.forEach(child => walkTree(child, cb, parents.concat([node])));
  }
}

// Get the list of ancestor node-ids for a given node id (used to auto-expand path to search results)
const nodeParentMap = {}; // nodeId -> array of ancestor ids (root first)
walkTree(TREE_DATA, (node, parents) => {
  nodeParentMap[node.id] = parents.map(p => p.id);
});

// Build a flat index of node id -> node object for quick lookup
const nodeIndex = {};
walkTree(TREE_DATA, (node) => { nodeIndex[node.id] = node; });

</script>

<script>
/* ============================================================
   TREE RENDERING
   ============================================================ */

// Determine if a node (or any descendant) matches current filters; used to decide visibility
function nodeMatchesFilters(node) {
  if (node.type !== 'organism') return true; // non-organism nodes are filtered based on descendants
  const org = ORGANISM_MAP[node.organismId];
  if (!org) return true;
  const f = state.activeFilters;
  if (f.gram.size > 0) {
    const gramSimple = org.gramReaction.toLowerCase().includes('gram-positive') ? 'positive' :
                        org.gramReaction.toLowerCase().includes('gram-negative') ? 'negative' : 'other';
    if (!f.gram.has(gramSimple)) return false;
  }
  if (f.oxygen.size > 0) {
    const ox = org.oxygenRequirement.toLowerCase();
    let oxKey = 'other';
    if (ox.includes('obligate aerobe') || (ox.includes('aerobic') && !ox.includes('anaerobic') && !ox.includes('facultative') && !ox.includes('microaerophilic'))) oxKey = 'aerobic';
    else if (ox.includes('strict anaerobe') || (ox.includes('anaerobic') && !ox.includes('facultative') && !ox.includes('aerobic'))) oxKey = 'anaerobic';
    else if (ox.includes('facultative')) oxKey = 'facultative';
    else if (ox.includes('microaerophilic')) oxKey = 'microaerophilic';
    else if (ox.includes('intracellular')) oxKey = 'intracellular';
    if (!f.oxygen.has(oxKey)) return false;
  }
  if (f.category.size > 0) {
    if (!f.category.has(org._category)) return false;
  }
  return true;
}

// Returns true if this node or any descendant organism passes filters AND (if searching) matches search
function subtreeVisible(node) {
  if (node.type === 'organism') {
    const passesFilter = nodeMatchesFilters(node);
    const passesSearch = state.searchQuery === '' || state.searchMatchIds.has(node.id);
    return passesFilter && passesSearch;
  }
  if (!node.children) return false;
  return node.children.some(child => subtreeVisible(child));
}

function isExpanded(nodeId) {
  return state.expandedNodes.has(nodeId);
}

function toggleExpand(nodeId) {
  if (state.expandedNodes.has(nodeId)) {
    state.expandedNodes.delete(nodeId);
  } else {
    state.expandedNodes.add(nodeId);
  }
  renderTree();
}

function countOrganismsInSubtree(node) {
  if (node.type === 'organism') return 1;
  if (!node.children) return 0;
  return node.children.reduce((sum, c) => sum + countOrganismsInSubtree(c), 0);
}

function renderNode(node, depth) {
  if (!subtreeVisible(node)) return '';

  const hasChildren = node.children && node.children.length > 0;
  const expanded = isExpanded(node.id) || (state.searchQuery !== '' && state.searchMatchIds.size > 0);
  const isLeaf = !hasChildren;
  const isSearchMatch = state.searchQuery !== '' && state.searchMatchIds.has(node.id) && node.type === 'organism';

  let boxClasses = ['tree-node-box', 'type-' + node.type];
  if (node.category) boxClasses.push(getCategoryClass(node.category));
  if (node.type === 'organism') {
    const org = ORGANISM_MAP[node.organismId];
    if (org) boxClasses.push(getCategoryClass(org._category));
    if (state.compareList.includes(node.organismId)) boxClasses.push('in-comparison');
  }
  if (isSearchMatch) boxClasses.push('search-match');
  if (state.selectedOrganismId && node.organismId === state.selectedOrganismId) boxClasses.push('search-current');

  const toggleIconHtml = isLeaf && node.type !== 'organism'
    ? ''
    : `<svg class="tree-toggle-icon ${expanded ? 'expanded' : ''} ${isLeaf ? 'leaf' : ''}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>`;

  let labelHtml = highlightMatch(node.label, state.searchQuery);
  let noteHtml = node.note ? `<span class="tree-node-note">— ${escapeHtml(node.note)}</span>` : '';
  let countTag = '';
  if (node.type === 'category' || node.type === 'genus') {
    const cnt = countOrganismsInSubtree(node);
    countTag = `<span class="tree-organism-count-tag">${cnt} organism${cnt !== 1 ? 's' : ''}</span>`;
  }

  let compareCheckbox = '';
  if (node.type === 'organism') {
    const checked = state.compareList.includes(node.organismId) ? 'checked' : '';
    compareCheckbox = `<input type="checkbox" class="tree-compare-checkbox" data-organism-id="${node.organismId}" ${checked} title="Add to comparison" onclick="event.stopPropagation(); handleCompareCheckbox('${node.organismId}', this.checked)">`;
  }

  const clickHandler = node.type === 'organism'
    ? `selectOrganism('${node.organismId}')`
    : `toggleExpand('${node.id}')`;

  const nodeBoxHtml = `
    <div class="tree-node-box ${boxClasses.slice(1).join(' ')}" tabindex="0" role="button"
         onclick="${clickHandler}"
         onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();${clickHandler}}"
         data-node-id="${node.id}">
      ${toggleIconHtml}
      ${compareCheckbox}
      <span>${labelHtml}</span>
      ${noteHtml}
      ${countTag}
    </div>`;

  let childrenHtml = '';
  if (hasChildren) {
    const childNodes = node.children.map(child => renderNode(child, depth + 1)).filter(h => h !== '').join('');
    childrenHtml = `<div class="tree-children-container ${expanded ? '' : 'collapsed'}">
      <div class="tree-node-wrap">${childNodes}</div>
    </div>`;
  }

  return `<div class="tree-node-row">${nodeBoxHtml}${childrenHtml}</div>`;
}

function renderTree() {
  const rootEl = document.getElementById('treeRoot');
  const rootHasChildren = TREE_DATA.children && TREE_DATA.children.length > 0;
  const expanded = isExpanded('root') || (state.searchQuery !== '' && state.searchMatchIds.size > 0);

  const childrenHtml = TREE_DATA.children
    .map(child => renderNode(child, 1))
    .filter(h => h !== '')
    .join('');

  const noResultsHtml = (state.searchQuery !== '' && childrenHtml === '')
    ? `<div style="padding:40px 10px;color:var(--ink-soft);font-size:0.92rem;">No organisms match "${escapeHtml(state.searchQuery)}"${hasActiveFilters() ? ' with the current filters' : ''}.</div>`
    : '';

  rootEl.innerHTML = `
    <div class="tree-node-row">
      <div class="tree-node-box type-root no-line" tabindex="0" role="button"
           onclick="toggleExpand('root')"
           onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleExpand('root')}"
           data-node-id="root">
        <svg class="tree-toggle-icon ${expanded ? 'expanded' : ''}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px;"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Bacteria</span>
      </div>
      <div class="tree-children-container ${expanded ? '' : 'collapsed'}">
        <div class="tree-node-wrap">${childrenHtml}${noResultsHtml}</div>
      </div>
    </div>
  `;
}

function hasActiveFilters() {
  const f = state.activeFilters;
  return f.gram.size > 0 || f.oxygen.size > 0 || f.category.size > 0;
}

function expandAll() {
  walkTree(TREE_DATA, (node) => { state.expandedNodes.add(node.id); });
  renderTree();
}
function collapseAll() {
  state.expandedNodes.clear();
  state.expandedNodes.add('root');
  renderTree();
}

</script>

