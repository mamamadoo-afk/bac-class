  state.expandablePanelOpen = false;
  // Auto-expand the path to this organism in the tree
  const leafNodeId = Object.keys(nodeIndex).find(id => nodeIndex[id].type === 'organism' && nodeIndex[id].organismId === organismId);
  if (leafNodeId) {
    const ancestors = nodeParentMap[leafNodeId] || [];
    ancestors.forEach(a => state.expandedNodes.add(a));
  }
  renderOrganismPanel(organismId);
  renderTree();
  // Scroll node into view
  setTimeout(() => {
    const el = document.querySelector(`[data-node-id="${leafNodeId}"]`);
    if (el && typeof el.scrollIntoView === 'function') el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }, 50);
}

function closeSidePanel() {
  document.getElementById('sidePanel').classList.remove('open');
  state.selectedOrganismId = null;
  renderTree();
}

</script>

<script>
/* ============================================================
   SEARCH
   ============================================================ */

// Build a searchable text blob per organism node (name, diseases, tests along its path, classification path)
function buildSearchIndex() {
  const index = []; // { nodeId, organismId, searchableText, displayName, pathLabel }
  walkTree(TREE_DATA, (node) => {
    if (node.type === 'organism') {
      const org = ORGANISM_MAP[node.organismId];
      if (!org) return;
      const pathLabels = (nodeParentMap[node.id] || []).map(id => nodeIndex[id].label).join(' > ');
      const searchableParts = [
        org.scientificName,
        node.label,
        org.classificationPath,
        ...(org.diseases || []),
        ...(org.distinguishingFeatures || [])
      ].join(' ').toLowerCase();
      index.push({
        nodeId: node.id,
        organismId: node.organismId,
        searchableText: searchableParts,
        displayName: org.scientificName,
        pathLabel: pathLabels
      });
    }
  });
  return index;
}
const SEARCH_INDEX = buildSearchIndex();

function runSearch(query) {
  state.searchQuery = query.trim();
  if (state.searchQuery === '') {
    state.searchMatchIds.clear();
    renderTree();
    hideSearchDropdown();
    return;
  }
  const q = state.searchQuery.toLowerCase();
  const matches = SEARCH_INDEX.filter(entry => entry.searchableText.includes(q));
  state.searchMatchIds = new Set(matches.map(m => m.nodeId));

  // Auto-expand ancestor paths for all matches
  matches.forEach(m => {
    (nodeParentMap[m.nodeId] || []).forEach(a => state.expandedNodes.add(a));
  });

  renderTree();
  renderSearchDropdown(matches.slice(0, 12));
}

function renderSearchDropdown(matches) {
  const dropdown = document.getElementById('searchDropdown');
  if (matches.length === 0) {
    dropdown.innerHTML = `<div class="search-no-results">No matches found.</div>`;
  } else {
    dropdown.innerHTML = matches.map(m => `
      <div class="search-result-item" onclick="jumpToOrganism('${m.organismId}')">
        <span class="search-result-name">${highlightMatch(m.displayName, state.searchQuery)}</span>
        <span class="search-result-path">${escapeHtml(m.pathLabel)}</span>
      </div>
    `).join('');
  }
  dropdown.classList.add('visible');
}
function hideSearchDropdown() {
  document.getElementById('searchDropdown').classList.remove('visible');
}

function jumpToOrganism(organismId) {
  selectOrganism(organismId);
  hideSearchDropdown();
}

/* ============================================================
   FILTERS
   ============================================================ */
const FILTER_DEFS = {
  gram: [
    { key: 'positive', label: 'Gram-positive' },
    { key: 'negative', label: 'Gram-negative' },
    { key: 'other', label: 'Other / N/A' }
  ],
  oxygen: [
    { key: 'aerobic', label: 'Aerobic' },
    { key: 'anaerobic', label: 'Anaerobic' },
    { key: 'facultative', label: 'Facultative' },
    { key: 'microaerophilic', label: 'Microaerophilic' },
    { key: 'intracellular', label: 'Obligate Intracellular' },
    { key: 'other', label: 'Other' }
  ],
  category: [
    { key: 'grampos', label: 'Gram-Positive Group' },
    { key: 'gramneg', label: 'Gram-Negative Group' },
    { key: 'acidfast', label: 'Acid-Fast' },
    { key: 'intracellular', label: 'Intracellular' },
    { key: 'other', label: 'Spirochetes / Cell-wall-deficient' }
  ]
};

function renderFilterChips() {
  Object.keys(FILTER_DEFS).forEach(groupKey => {
    const container = document.getElementById('filterGroup-' + groupKey);
    container.innerHTML = FILTER_DEFS[groupKey].map(opt => {
      const active = state.activeFilters[groupKey].has(opt.key);
      return `<span class="filter-chip ${active ? 'active' : ''}" onclick="toggleFilter('${groupKey}', '${opt.key}')">${escapeHtml(opt.label)}</span>`;
    }).join('');
  });
  updateFilterBadge();
}

function toggleFilter(groupKey, optKey) {
  const set = state.activeFilters[groupKey];
  if (set.has(optKey)) set.delete(optKey); else set.add(optKey);
  renderFilterChips();
  renderTree();
}

function clearAllFilters() {
  Object.values(state.activeFilters).forEach(s => s.clear());
  renderFilterChips();
  renderTree();
}

function updateFilterBadge() {
  const total = state.activeFilters.gram.size + state.activeFilters.oxygen.size + state.activeFilters.category.size;
  const badge = document.getElementById('filterCountBadge');
  if (total > 0) {
    badge.style.display = 'inline-block';
    badge.textContent = total;
  } else {
    badge.style.display = 'none';
  }
}

/* ============================================================
   QUICK JUMP
   ============================================================ */
function renderQuickJumpList(filterText) {
  const list = document.getElementById('quickJumpList');
  const q = (filterText || '').toLowerCase();
  const filtered = SEARCH_INDEX.filter(e => e.searchableText.includes(q));

  // Group alphabetically by first letter of scientific name
  const grouped = {};
  filtered.sort((a, b) => a.displayName.localeCompare(b.displayName));
  filtered.forEach(e => {
    const letter = e.displayName[0].toUpperCase();
    if (!grouped[letter]) grouped[letter] = [];
    grouped[letter].push(e);
  });

  let html = '';
  Object.keys(grouped).sort().forEach(letter => {
    html += `<div class="quickjump-group-label">${letter}</div>`;
    grouped[letter].forEach(e => {
      html += `<div class="quickjump-item" onclick="jumpToOrganism('${e.organismId}'); closeQuickJump();">${escapeHtml(e.displayName)}</div>`;
    });
  });
  if (filtered.length === 0) {
    html = `<div class="search-no-results">No organisms found.</div>`;
  }
  list.innerHTML = html;
}

function openQuickJump() {
  document.getElementById('quickJumpOverlay').classList.add('visible');
  document.getElementById('quickJumpInput').value = '';
  renderQuickJumpList('');
  setTimeout(() => document.getElementById('quickJumpInput').focus(), 50);
}
function closeQuickJump() {
  document.getElementById('quickJumpOverlay').classList.remove('visible');
}

</script>

<script>
/* ============================================================
   COMPARISON TOOL
   ============================================================ */
const MAX_COMPARE = 4;

function handleCompareCheckbox(organismId, checked) {
  if (checked) {
    if (state.compareList.length >= MAX_COMPARE) {
      alert(`You can compare up to ${MAX_COMPARE} organisms at a time. Remove one before adding another.`);
      // revert checkbox visually
      renderTree();
      return;
    }
    if (!state.compareList.includes(organismId)) state.compareList.push(organismId);
  } else {
    state.compareList = state.compareList.filter(id => id !== organismId);
  }
  renderCompareTray();
  renderTree();
  if (state.selectedOrganismId === organismId) renderOrganismPanel(organismId);
}

function removeFromCompare(organismId) {
  state.compareList = state.compareList.filter(id => id !== organismId);
  renderCompareTray();
  renderTree();
  if (document.getElementById('compareModalOverlay').classList.contains('visible')) {
    renderCompareModal();
  }
}

function clearCompare() {
  state.compareList = [];
  renderCompareTray();
  renderTree();
}

function renderCompareTray() {
  const tray = document.getElementById('compareTray');
  const chipsEl = document.getElementById('compareTrayChips');
  document.getElementById('compareCount').textContent = state.compareList.length;

  if (state.compareList.length === 0) {
    tray.classList.remove('visible');
    return;
  }
  tray.classList.add('visible');
  chipsEl.innerHTML = state.compareList.map(id => {
    const org = ORGANISM_MAP[id];
    return `<span class="compare-tray-chip">${escapeHtml(org.scientificName)}<button onclick="removeFromCompare('${id}')" aria-label="Remove">×</button></span>`;
  }).join('');
}

const COMPARE_ROWS = [
  { key: 'classificationPath', label: 'Classification' },
  { key: 'gramReaction', label: 'Gram Reaction' },
  { key: 'morphology', label: 'Morphology' },
  { key: 'arrangement', label: 'Arrangement' },
  { key: 'oxygenRequirement', label: 'Oxygen Req.' },
  { key: 'distinguishingFeatures', label: 'Distinguishing Features', isList: true },
  { key: 'virulenceFactors', label: 'Virulence Factors', isList: true },
  { key: 'diseases', label: 'Diseases', isList: true },
  { key: 'labDiagnosis', label: 'Lab Diagnosis', isList: true },
  { key: 'examPearls', label: 'Exam Pearls', isList: true }
];

function renderCompareModal() {
  const table = document.getElementById('compareTable');
  if (state.compareList.length === 0) {
    table.innerHTML = `<tr><td class="compare-placeholder-cell">No organisms selected. Check the comparison checkbox next to any organism in the tree to add it here.</td></tr>`;
    return;
  }

  let headerHtml = `<thead><tr><th></th>`;
  state.compareList.forEach(id => {
    const org = ORGANISM_MAP[id];
    headerHtml += `<th>${escapeHtml(org.scientificName)}<br/><button class="compare-remove-col-btn" onclick="removeFromCompare('${id}')">Remove</button></th>`;
  });
  headerHtml += `</tr></thead>`;

  let bodyHtml = `<tbody>`;
  COMPARE_ROWS.forEach(row => {
    bodyHtml += `<tr><th>${escapeHtml(row.label)}</th>`;
    state.compareList.forEach(id => {
      const org = ORGANISM_MAP[id];
      const val = org[row.key];
      let cellContent;
      if (row.isList) {
        cellContent = (val && val.length > 0)
          ? `<ul class="ct-list">${val.map(v => `<li>${escapeHtml(v)}</li>`).join('')}</ul>`
          : '<span style="color:var(--ink-soft);font-style:italic;">—</span>';
      } else {
        cellContent = val ? escapeHtml(val) : '<span style="color:var(--ink-soft);font-style:italic;">—</span>';
      }
      bodyHtml += `<td>${cellContent}</td>`;
    });
    bodyHtml += `</tr>`;
  });
  bodyHtml += `</tbody>`;

  table.innerHTML = headerHtml + bodyHtml;
}

function openCompareModal() {
  renderCompareModal();
  document.getElementById('compareModalOverlay').classList.add('visible');
}
function closeCompareModal() {
  document.getElementById('compareModalOverlay').classList.remove('visible');
}

</script>

<script>
/* ============================================================
   EVENT WIRING & INIT
   ============================================================ */

document.addEventListener('DOMContentLoaded', () => {
  renderTree();
  renderFilterChips();
  renderCompareTray();

  // --- Search ---
  const searchInput = document.getElementById('searchInput');
  const searchClearBtn = document.getElementById('searchClearBtn');
  const debouncedSearch = debounce((val) => runSearch(val), 180);

  searchInput.addEventListener('input', (e) => {
    const val = e.target.value;
    searchClearBtn.classList.toggle('visible', val.length > 0);
    debouncedSearch(val);
  });
  searchInput.addEventListener('focus', () => {
    if (state.searchQuery !== '') document.getElementById('searchDropdown').classList.add('visible');
  });
  searchClearBtn.addEventListener('click', () => {
    searchInput.value = '';
    searchClearBtn.classList.remove('visible');
    runSearch('');
  });
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.search-wrap')) hideSearchDropdown();
  });
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { searchInput.value=''; searchClearBtn.classList.remove('visible'); runSearch(''); searchInput.blur(); }
  });

  // --- Filter panel toggle ---
  const filterToggleBtn = document.getElementById('filterToggleBtn');
  const filterPanel = document.getElementById('filterPanel');
  filterToggleBtn.addEventListener('click', () => {
    const willOpen = !filterPanel.classList.contains('open');
    filterPanel.classList.toggle('open');
    filterToggleBtn.setAttribute('aria-expanded', willOpen);
    filterToggleBtn.classList.toggle('btn-active', willOpen);
  });
  document.getElementById('filterClearLink').addEventListener('click', clearAllFilters);

  // --- Expand / collapse all ---
  document.getElementById('expandAllBtn').addEventListener('click', expandAll);
  document.getElementById('collapseAllBtn').addEventListener('click', collapseAll);

  // --- Quick jump ---
  document.getElementById('quickJumpBtn').addEventListener('click', openQuickJump);
  document.getElementById('quickJumpOverlay').addEventListener('click', (e) => {
    if (e.target.id === 'quickJumpOverlay') closeQuickJump();
  });
  document.getElementById('quickJumpInput').addEventListener('input', (e) => renderQuickJumpList(e.target.value));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeQuickJump();
    // Cmd/Ctrl+K to open quick jump
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openQuickJump();
    }
  });

  // --- Compare tray / modal ---
  document.getElementById('openCompareBtn').addEventListener('click', openCompareModal);
  document.getElementById('clearCompareBtn').addEventListener('click', clearCompare);
  document.getElementById('closeCompareModalBtn').addEventListener('click', closeCompareModal);
  document.getElementById('compareModalOverlay').addEventListener('click', (e) => {
    if (e.target.id === 'compareModalOverlay') closeCompareModal();
  });
});
</script>

